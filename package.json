{  "name": "chatgpt-archive",  "displayName": "ChatGPT Archive - Secure Backup & Viewer",  "version": "1.0.0",  "description": "Backup & view ChatGPT conversations offline. PIN protection, search, exports to Notion/Obsidian.",  "author": "ChatGPT Archive Team",  "license": "MIT",  "homepage": "https://github.com/yourusername/chatgpt-archive",  "repository": {    "type": "git",    "url": "https://github.com/yourusername/chatgpt-archive.git"  },  "bugs": {    "url": "https://github.com/yourusername/chatgpt-archive/issues"  },  "keywords": [    "chatgpt",    "backup",    "export",    "json",    "markdown",    "obsidian",    "notion",    "workflowy",    "conversations",    "history",    "archive",    "privacy",    "encrypted",    "open-source"  ],  "scripts": {    "dev": "wxt",    "dev:firefox": "wxt -b firefox",    "build": "wxt build",    "build:firefox": "wxt build -b firefox",    "zip": "wxt zip",    "zip:firefox": "wxt zip -b firefox",    "compile": "tsc --noEmit",    "postinstall": "wxt prepare",    "lint": "eslint src --ext .ts,.tsx",    "format": "prettier --write \"src/**/*.{ts,tsx,css,html}\"",    "test": "vitest run",    "test:watch": "vitest",    "test:coverage": "vitest run --coverage",    "test:e2e": "playwright test",    "test:e2e:ui": "playwright test --ui",    "test:e2e:debug": "playwright test --debug"  },  "devDependencies": {    "@playwright/test": "^1.40.0",    "@types/chrome": "^0.0.254",    "@typescript-eslint/eslint-plugin": "^6.0.0",    "@typescript-eslint/parser": "^6.0.0",    "@vitest/coverage-v8": "^1.0.0",    "@webext-core/fake-browser": "^1.0.0",    "eslint": "^8.45.0",    "jsdom": "^23.0.0",    "prettier": "^3.0.0",    "sharp": "^0.34.5",    "typescript": "^5.3.3",    "vitest": "^1.0.0",    "wxt": "^0.17.0"  },  "dependencies": {    "@notionhq/client": "^2.2.0",    "fuse.js": "^7.0.0",    "pako": "^2.1.0"  }}